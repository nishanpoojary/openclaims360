{
    "compilerOptions": {
        "target": "ES2021",
        "module": "commonjs",
        "strict": true,
        "esModuleInterop": true,
        "skipLibCheck": true,
        "forceConsistentCasingInFileNames": true,
        "outDir": "cdk.out"
    },
    "include": [
        "bin/**/*.ts",
        "lib/**/*.ts"
    ]
}