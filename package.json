{
    "name": "openclaims360",
    "version": "0.1.0",
    "license": "MIT",
    "description": "AWS CDK stacks and Lambda source for the OpenClaims 360 free-tier fraud-detection project",
    "engines": {
        "node": ">=18.0.0"
    },
    "scripts": {
        "build": "tsc",
        "watch": "tsc -w",
        "cdk:diff": "npm run build && cdk diff",
        "cdk:deploy": "npm run build && cdk deploy --all",
        "cdk:destroy": "cdk destroy --all"
    },
    "dependencies": {
        "aws-cdk-lib": "2.139.0",
        "constructs": "^10.3.0",
        "source-map-support": "^0.5.21"
    },
    "devDependencies": {
        "@types/node": "^20.17.52",
        "ts-node": "^10.9.2",
        "typescript": "^5.8.3"
    }
}
